# Local server
API_HOST=127.0.0.1
API_PORT=8000

# Backend
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_DAYS=30
API_HOST=127.0.0.1
API_PORT=8000
DB_PATH=mental_health.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM and ASR endpoints
LLM_MODE=auto
LLM_API_URL=
LLM_LOCAL_MODEL_PATH=Counselor_Llama3_Q4.gguf
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SEC=120
ASR_WS_URL=ws://localhost:9000/ws/asr

# Prompt and model tuning
PROMPT_PRESET=default
PROMPT_HISTORY_TURNS=6
CRISIS_THRESHOLD=0.55
DETECTION_MODELS_DIR=backend/models/detection
DETECTION_MAX_LEN=256
DETECTION_STRIDE=64

# Runtime controls
SESSION_TTL_HOURS=4
SESSION_MAX=200
RATE_LIMIT=30
RATE_WINDOW_SEC=60

# Frontend (Vite)
VITE_API_BASE=http://localhost:8000
VITE_ASR_WS_URL=ws://localhost:9000/ws/asr
